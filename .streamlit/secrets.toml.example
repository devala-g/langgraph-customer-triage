# Streamlit Community Cloud: paste these under Settings → Secrets (TOML format).
# For LOCAL runs you can use .env instead — this file is only a template.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Optional — enables LangSmith tracing of every run (free tier at smith.langchain.com)
LANGSMITH_TRACING = "true"
LANGSMITH_API_KEY = "lsv2_your-key-here"
LANGSMITH_PROJECT = "customer-triage-demo"
LANGSMITH_ENDPOINT = "https://api.smith.langchain.com"
